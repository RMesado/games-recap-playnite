<UserControl x:Class="GamesRecap.GamesRecapSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <StackPanel Margin="10">
        <TextBlock Text="{DynamicResource SettingsDefaultAction}" Style="{StaticResource BaseTextBlockStyle}" Margin="0,0,0,4"/>
        <ComboBox ItemsSource="{Binding WishlistActions}"
                  SelectedValue="{Binding Settings.DefaultWishlistAction}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"/>

        <TextBlock Style="{StaticResource BaseTextBlockStyle}"
                   Text="{DynamicResource SettingsNote}"
                   TextWrapping="Wrap"
                   Visibility="{Binding IsAddToLibraryAction, Converter={StaticResource BoolToVis}}"
                   Margin="0,8,0,4"/>

        <CheckBox IsChecked="{Binding Settings.ShowConfirmation}"
                   Content="{DynamicResource SettingsShowConfirmation}"
                   Margin="0,12,0,0">
            <CheckBox.Style>
                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddToLibraryAction}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </CheckBox.Style>
        </CheckBox>

        <TextBlock Text="{DynamicResource SettingsCalendarRefreshInterval}" Style="{StaticResource BaseTextBlockStyle}" Margin="0,16,0,4"/>
        <ComboBox ItemsSource="{Binding CalendarRefreshPresets}"
                  SelectedItem="{Binding SelectedCalendarPreset}"
                  DisplayMemberPath="Display"
                  Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Visibility="{Binding IsCustomPreset, Converter={StaticResource BoolToVis}}">
            <TextBox Text="{Binding CalendarCustomDaysText, UpdateSourceTrigger=PropertyChanged}"
                     Width="60" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource SettingsCalendarDaysLabel}" Style="{StaticResource BaseTextBlockStyle}" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="{DynamicResource SettingsCalendarNotificationsHeader}" Style="{StaticResource BaseTextBlockStyle}" Margin="0,16,0,4"/>
        <CheckBox IsChecked="{Binding Settings.CalendarNotifyMonthBefore}"
                  Content="{DynamicResource SettingsCalendarNotifyMonth}" Margin="0,2,0,0"/>
        <CheckBox IsChecked="{Binding Settings.CalendarNotifyWeekBefore}"
                  Content="{DynamicResource SettingsCalendarNotifyWeek}" Margin="0,2,0,0"/>
        <CheckBox IsChecked="{Binding Settings.CalendarNotifyDayBefore}"
                  Content="{DynamicResource SettingsCalendarNotifyDay}" Margin="0,2,0,0"/>
        <CheckBox IsChecked="{Binding Settings.CalendarNotifySameDay}"
                  Content="{DynamicResource SettingsCalendarNotifySameDay}" Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>