<UserControl x:Class="GamesRecap.Views.BrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:GamesRecap.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringNotNullToVisibilityConverter x:Key="StringNotNullToVis" />
    </UserControl.Resources>
    <Grid Background="{DynamicResource WindowBackgourndBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PopupBackgroundBrush}" BorderBrush="{DynamicResource PopupBorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">

                    <TextBlock Text="Buscar" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,0,0,4" />
                    <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" KeyDown="SearchBox_KeyDown"
                             Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource NormalBorderBrush}"
                             BorderThickness="1" Padding="6" />

                    <TextBlock Text="Ordenar" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,10,0,4" />
                    <ComboBox ItemsSource="{Binding SortOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedSort}"
                              Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource NormalBorderBrush}"
                              BorderThickness="1" Padding="4" />

                    <TextBlock Text="Plataformas" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,10,0,4" />
                    <ItemsControl ItemsSource="{Binding PlatformFilters}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource TextBrush}" Margin="2,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Géneros" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,6,0,4" />
                    <ItemsControl ItemsSource="{Binding GenreFilters}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource TextBrush}" Margin="2,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Tags" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,6,0,4" />
                    <ItemsControl ItemsSource="{Binding TagFilters}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource TextBrush}" Margin="2,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Showcases" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" Margin="0,6,0,4" />
                    <ItemsControl ItemsSource="{Binding ShowcaseFilters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="{DynamicResource TextBrush}" Margin="2,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource PanelSeparatorBrush}" ShowsPreview="False" ResizeBehavior="PreviousAndNext" />

        <Grid Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotNullToVis}}" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Margin="8" Background="{DynamicResource GridItemBackgroundBrush}" BorderBrush="{DynamicResource NormalBorderBrush}" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="120" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Background="{DynamicResource NormalBrushDark}" CornerRadius="4,4,0,0" ClipToBounds="True">
                                        <Image Source="{Binding CoverUrl}" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" MaxHeight="120" />
                                    </Border>

                                    <TextBlock Grid.Row="1" Text="{Binding Title}" Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrush}"
                                               FontSize="{DynamicResource FontSize}" FontWeight="Bold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                               Margin="8,6,8,2" ToolTip="{Binding Title}" />

                                    <TextBlock Grid.Row="2" Text="{Binding ShowcaseName}" Foreground="{DynamicResource GlyphBrush}" FontSize="11"
                                               Margin="8,0,8,2" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding ShowcaseName, Converter={StaticResource StringNotNullToVis}}" />

                                    <TextBlock Grid.Row="3" Text="{Binding PlatformNames}" Foreground="{DynamicResource TextBrushDarker}" FontSize="11"
                                               Margin="8,0,8,2" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding PlatformNames, Converter={StaticResource StringNotNullToVis}}" />

                                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="8,0,8,4">
                                        <TextBlock Text="{Binding ReleaseDate}" Foreground="{DynamicResource TextBrushDarker}" FontSize="11"
                                                   Visibility="{Binding ReleaseDate, Converter={StaticResource StringNotNullToVis}}" />
                                        <TextBlock Text="{Binding GenreNames}" Foreground="{DynamicResource TextBrushDarker}" FontSize="11"
                                                   Margin="4,0,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding GenreNames, Converter={StaticResource StringNotNullToVis}}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="6,0,6,6" HorizontalAlignment="Center">
                                        <Button Content="Ver tráiler" Command="{Binding DataContext.OpenTrailerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding TrailerUrl}" Padding="8,3" Margin="2"
                                                Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource NormalBorderBrush}"
                                                Visibility="{Binding HasTrailer, Converter={StaticResource BoolToVis}}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{DynamicResource NormalBrush}" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button Content="♥" Command="{Binding DataContext.ToggleWishlistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding GameId}" Padding="8,3" Margin="2" FontSize="16"
                                                BorderBrush="{DynamicResource NormalBorderBrush}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{DynamicResource NormalBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrushDarker}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWishlisted}" Value="True">
                                                            <Setter Property="Foreground" Value="#ff506e" />
                                                            <Setter Property="Background" Value="{DynamicResource NormalBrushDark}" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{DynamicResource PopupBackgroundBrush}" BorderBrush="{DynamicResource PopupBorderBrush}" BorderThickness="0,1,0,0" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button Content="◀ Anterior" Command="{Binding PrevPageCommand}" Padding="10,4" Margin="0,0,8,0"
                                        Background="{DynamicResource NormalBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource NormalBorderBrush}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Style="{DynamicResource BaseTextBlockStyle}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center">
                                    <Run Text="Página" /><Run Text=" " /><Run Text="{Binding CurrentPage}" /><Run Text=" de " /><Run Text="{Binding TotalPages}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding TotalCards, StringFormat='  ({0} cards)'}" Foreground="{DynamicResource TextBrushDarker}" FontSize="{DynamicResource FontSizeSmall}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                    </StackPanel>

                                    <Button Grid.Column="2" Content="Siguiente ▶" Command="{Binding NextPageCommand}" Padding="10,4"
                                    Background="{DynamicResource NormalBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource NormalBorderBrush}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
</UserControl>
