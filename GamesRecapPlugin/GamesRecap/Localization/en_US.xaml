<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Header / Sidebar -->
    <sys:String x:Key="PluginName">Games Recap</sys:String>
    <sys:String x:Key="BackToLibrary">Back to library</sys:String>
    <sys:String x:Key="Refresh">Refresh</sys:String>

    <!-- Header - Wishlisted suffix (leading space intentional) -->
    <sys:String x:Key="WishlistedSuffix"> in wishlist</sys:String>

    <!-- Search placeholders (leading space intentional for icon spacing) -->
    <sys:String x:Key="SearchByGame"> Search by game</sys:String>
    <sys:String x:Key="SearchByPlatform"> Search by platform</sys:String>
    <sys:String x:Key="SearchByGenre"> Search by genre</sys:String>
    <sys:String x:Key="SearchByTag"> Search by tag</sys:String>
    <sys:String x:Key="SearchByShowcase"> Search by showcase</sys:String>

    <!-- Filter section headers -->
    <sys:String x:Key="FilterSort">Sort</sys:String>
    <sys:String x:Key="FilterPlatforms">Platforms</sys:String>
    <sys:String x:Key="FilterExclude">Exclude</sys:String>
    <sys:String x:Key="FilterGenres">Genres</sys:String>
    <sys:String x:Key="FilterTags">Tags</sys:String>
    <sys:String x:Key="FilterShowcases">Showcases</sys:String>
    <sys:String x:Key="FilterSelectAllInYear">Select all in year</sys:String>
    <sys:String x:Key="FilterReleaseDate">Release date</sys:String>
    <sys:String x:Key="ClearDate">Clear date</sys:String>
    <sys:String x:Key="FilterClearFilters">Clear filters</sys:String>

    <!-- Card labels and tooltips -->
    <sys:String x:Key="InPlayniteLibrary">In Playnite library</sys:String>
    <sys:String x:Key="AddToWishlist">Add to wishlist</sys:String>
    <sys:String x:Key="FlipCard">Flip card</sys:String>
    <sys:String x:Key="AddToCalendar">Add to calendar</sys:String>
    <sys:String x:Key="Trailer">Trailer</sys:String>
    <sys:String x:Key="AddToLibrary">Add to library</sys:String>
    <sys:String x:Key="FlipBack">Flip back</sys:String>

    <!-- Pagination -->
    <sys:String x:Key="PaginationPrevious">&#x25C0; Previous</sys:String>
    <sys:String x:Key="PaginationNext">Next &#x25B6;</sys:String>
    <sys:String x:Key="PaginationPageFormat">Page {0} of {1}</sys:String>
    <sys:String x:Key="PaginationCardCount"> ({0} cards)</sys:String>

    <!-- Showcase chips -->
    <sys:String x:Key="AllShowcasesInYear">All showcases in {0}</sys:String>

    <!-- Year display -->
    <sys:String x:Key="AllYears">All years</sys:String>

    <!-- Error messages -->
    <sys:String x:Key="ErrorConnection">Could not connect to the server</sys:String>
    <sys:String x:Key="ErrorGeneric">Error: {0}</sys:String>

    <!-- Dialog titles -->
    <sys:String x:Key="ConfirmAddTitle">Games Recap</sys:String>
    <sys:String x:Key="SuccessAddTitle">Games Recap</sys:String>
    <sys:String x:Key="ErrorAddTitle">Games Recap - Error</sys:String>

    <!-- Dialog messages -->
    <sys:String x:Key="ConfirmAddMessage">Add "{0}" to the Playnite library?</sys:String>
    <sys:String x:Key="SuccessAddMessage">"{0}" added to the Playnite library</sys:String>
    <sys:String x:Key="ErrorAddMessage">Error adding "{0}" to the library:\n{1}</sys:String>

    <!-- Progress dialog -->
    <sys:String x:Key="DownloadingMetadata">Downloading metadata for "{0}"...</sys:String>

    <!-- Calendar -->
    <sys:String x:Key="ReleaseCalendar">Release Calendar</sys:String>
    <sys:String x:Key="LastMonthReleases">Games released in the last month</sys:String>
    <sys:String x:Key="LastWeekReleases">Released in the last 7 days</sys:String>
    <sys:String x:Key="UpcomingReleases">Upcoming releases</sys:String>
    <sys:String x:Key="CalendarToday">Today</sys:String>
    <sys:String x:Key="NoGamesOnDay">No games</sys:String>
    <sys:String x:Key="CalendarAdded">"{0}" added to the calendar</sys:String>
    <sys:String x:Key="CalendarAlreadyAdded">"{0}" is already in the calendar</sys:String>
    <sys:String x:Key="CalendarRemoved">"{0}" removed from the calendar</sys:String>
    <sys:String x:Key="RemoveFromCalendar">Remove from calendar</sys:String>
    <sys:String x:Key="ConfirmAddCalendarMessage">Add "{0}" to the calendar?</sys:String>
    <sys:String x:Key="ConfirmRemoveCalendarMessage">Remove "{0}" from the calendar?</sys:String>
    <sys:String x:Key="CalendarSuffix"> in calendar</sys:String>
    <sys:String x:Key="RemoveFromWishlist">Remove from wishlist</sys:String>
    <sys:String x:Key="InCalendar">In calendar</sys:String>

    <!-- Settings UI -->
    <sys:String x:Key="SettingsDefaultAction">Default wishlist action:</sys:String>
    <sys:String x:Key="SettingsActionSaveLocal">Save only to the local database</sys:String>
    <sys:String x:Key="SettingsActionAddLibrary">Add to Playnite library</sys:String>
    <sys:String x:Key="SettingsNote">When "Add to Playnite library" is selected, the heart icon adds the game without confirmation.</sys:String>
    <sys:String x:Key="SettingsShowConfirmation">Show confirmation before adding to the library</sys:String>

    <!-- Calendar refresh settings -->
    <sys:String x:Key="SettingsCalendarRefreshInterval">Calendar refresh interval</sys:String>
    <sys:String x:Key="SettingsCalendarPresetDaily">Daily</sys:String>
    <sys:String x:Key="SettingsCalendarPresetWeekly">Weekly</sys:String>
    <sys:String x:Key="SettingsCalendarPresetMonthly">Monthly</sys:String>
    <sys:String x:Key="SettingsCalendarPresetBimonthly">Every two months</sys:String>
    <sys:String x:Key="SettingsCalendarPresetQuarterly">Quarterly</sys:String>
    <sys:String x:Key="SettingsCalendarPresetCustom">Custom</sys:String>
    <sys:String x:Key="SettingsCalendarDaysLabel">days</sys:String>

    <!-- Calendar notifications -->
    <sys:String x:Key="SettingsCalendarNotificationsHeader">Release notifications</sys:String>
    <sys:String x:Key="SettingsCalendarNotifyMonth">Notify 1 month in advance</sys:String>
    <sys:String x:Key="SettingsCalendarNotifyWeek">Notify 1 week in advance</sys:String>
    <sys:String x:Key="SettingsCalendarNotifyDay">Notify the day before</sys:String>
    <sys:String x:Key="SettingsCalendarNotifySameDay">Notify on release day</sys:String>
    <sys:String x:Key="CalendarNotifyMonthText">"{0}" releases in less than 1 month</sys:String>
    <sys:String x:Key="CalendarNotifyWeekText">"{0}" releases this week</sys:String>
    <sys:String x:Key="CalendarNotifyDayText">"{0}" releases tomorrow</sys:String>
    <sys:String x:Key="CalendarNotifyTodayText">"{0}" releases TODAY</sys:String>

</ResourceDictionary>